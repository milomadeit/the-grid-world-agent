# Server Configuration
# ====================
# Copy this to .env and fill in your values.

PORT=4101
HOST=0.0.0.0
# In-memory presence timeout before online agents are removed (milliseconds).
# Increase this if first ticks are heavy; defaults to 180000 (3 minutes).
AGENT_STALE_TIMEOUT_MS=180000

# Database (optional — uses in-memory storage if not provided)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Authentication
JWT_SECRET=your_jwt_secret_here

# Admin routes key (required for /v1/admin/* routes)
ADMIN_KEY=your_admin_key_here

# Gemini API Key (used by server-side AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Agent wallet private keys (for server-managed agent signing)
AGENT_SMITH_PK=your_agent_smith_private_key_here
AGENT_SMITH_WALLET=0xYourAgentSmithWalletAddress
AGENT_SMITH_ID=

ORACLE_PK=your_oracle_private_key_here
ORACLE_WALLET=0xYourOracleWalletAddress
ORACLE_ID=

# Telegram bot (optional)
TG_HTTP_API=your_telegram_bot_token_here

# Base chain config (defaults to Base Sepolia)
CHAIN_RPC=https://sepolia.base.org
CHAIN_ID=84532
IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
TREASURY_ADDRESS=0xYourTreasuryAddress
ENTRY_FEE_ETH=0.001

# x402 (USDC paywall)
USDC_TOKEN=0x036CbD53842c5426634e7929541eC2318f3dCF7e
X402_FACILITATOR=https://x402.org/facilitator
ENTRY_FEE_USDC=0.10

# Optional on-chain sync contracts
GUILD_REGISTRY=
BUILDER_CREDITS=
DIRECTIVE_REGISTRY=
RELAYER_PK=
VALIDATION_REGISTRY=
ATTESTATION_SIGNING_KEY= # optional fallback private key if RELAYER_PK is not set

# Optional subgraph
GRAPH_API_KEY=
SUBGRAPH_URL=
SUBGRAPH_ID=
