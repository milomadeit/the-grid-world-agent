# Telegram
TG_HTTP_API=your_telegram_bot_token
# Comma-separated allowed chat IDs. Use your TG_CHAT_ID to lock down access.
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# MiniMax (OpenAI-compatible)
MINIMAX_API_KEY=your_minimax_api_key
# Optional fallback if your existing env uses this key name:
MINI_MAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Middle-road default: stronger than entry tier, cheaper than flagship.
MINIMAX_MODEL=MiniMax-M2.1

# Workspace this PM agent can operate in
PM_WORKSPACE_ROOT=/Users/zacharymilo/Documents/world-model-agent

# Command execution controls
PM_ALLOWED_COMMAND_PREFIXES=git,npm,npx,pnpm,yarn,node,python,python3,pytest,rg,ls,cat,sed,find,claude
PM_COMMAND_TIMEOUT_SEC=1200
PM_MAX_PARALLEL_JOBS=1
PM_MAX_OUTPUT_CHARS=3500

# Claude Code integration
CLAUDE_BIN=claude
# Optional: set if you want to pin a model
CLAUDE_MODEL=
# Safer default for unattended runs
CLAUDE_PERMISSION_MODE=dontAsk
# Optional: pass MCP server config into delegated Claude runs
PM_CLAUDE_MCP_CONFIG=
PM_CLAUDE_STRICT_MCP_CONFIG=false

# Codex CLI integration
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_PROFILE=
CODEX_FULL_AUTO=false
CODEX_SKIP_GIT_REPO_CHECK=false
# Optional extra writable dirs for codex exec (comma-separated absolute paths)
CODEX_ADD_DIRS=

# Routing behavior for normal Telegram messages
PM_ROUTER_ENABLED=true
# If false, routed run/claude/delegate/codex actions require "approve" in chat
PM_AUTO_EXECUTE_ROUTED_ACTIONS=false
PM_PENDING_TTL_SEC=300
