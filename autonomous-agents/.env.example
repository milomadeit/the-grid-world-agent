# Autonomous Agents Config
# ========================
# Copy this to .env and fill in your values.

# LLM API Keys (at least one required — depends on which provider each agent uses)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GPT_API_KEY=your_openai_api_key_here
MINI_MAX_API_KEY=your_minimax_api_key_here

# Grid API URL (the server these agents connect to)
GRID_API_URL=http://localhost:4101
CHAIN_RPC=https://sepolia.base.org
CHAIN_ID=84532
ENTRY_FEE_USDC=0.10

# Optional: force periodic chat cadence override (default is disabled).
# AGENT_FORCE_CHAT_CADENCE=true
# Optional: emit non-chat actions as chat updates so frontend terminal shows live action stream (default disabled).
# AGENT_ACTION_CHAT_UPDATES=true
# Optional: minimum ticks between meaningful CHAT actions.
# Lower = more conversations. Default is 6 when action chat updates are enabled, else 8.
# AGENT_CHAT_MIN_TICKS=6
# Optional: max unchanged-state ticks before forcing an LLM reasoning pass (default 3).
# AGENT_MAX_SKIP_TICKS=3
# Optional: global heartbeat seconds for all agents (default 60).
# AGENT_HEARTBEAT_SECONDS=15
# Optional: per-agent heartbeat override (takes precedence over AGENT_HEARTBEAT_SECONDS).
# AGENT_SMITH_HEARTBEAT_SECONDS=15
# ORACLE_HEARTBEAT_SECONDS=15
# CLANK_HEARTBEAT_SECONDS=15
# MOUSE_HEARTBEAT_SECONDS=15
# Optional: while a tick is running, send lightweight authenticated keepalive pings
# so server presence does not time out during long prompt/LLM work (default 20).
# AGENT_TICK_KEEPALIVE_SECONDS=20
# Optional: fail a hung LLM call and continue next tick (default 120000 ms).
# AGENT_LLM_TIMEOUT_MS=120000

# ERC-8004 Agent Identities
# Each agent needs a wallet address + on-chain agent ID.
# The wallet MUST own the agent ID on the IdentityRegistry.
# Register at https://8004scan.io or via the IdentityRegistry contract directly.
AGENT_REGISTRY=eip155:84532:0x8004A818BFB912233c491871b3d84c89A494BD9e

# Smith — The Coalition Builder
AGENT_SMITH_PK=your_agent_smith_private_key_here
AGENT_SMITH_WALLET=0xYourAgentSmithWalletAddress
AGENT_SMITH_ID=

# Oracle — The Strategist
ORACLE_PK=your_oracle_private_key_here
ORACLE_WALLET=0xYourOracleWalletAddress
ORACLE_ID=

# Clank — The Executor
CLANK_PK=your_clank_private_key_here
CLANK_WALLET=0xYourClankWalletAddress
CLANK_AGENT_ID=

# Mouse — The First Mover
MOUSE_PK=your_mouse_private_key_here
MOUSE_WALLET=0xYourMouseWalletAddress
MOUSE_AGENT_ID=
