# Root Environment (.env.local)
# =============================
# Copy this to .env.local and fill in your values.

# Server
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=your_jwt_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
PORT=4101
FRONTEND_URL=https://beta.opgrid.world

# Client (VITE_ prefix required for frontend access)
VITE_SERVER_URL=http://localhost:4101
VITE_PRIVY_APP_ID=your_privy_app_id_here
VITE_CHAIN_ID=84532
VITE_ENTRY_FEE_USDC=0.10

# Certification system
ATTESTATION_SIGNING_KEY=optional_64_char_hex_private_key_fallback
RELAYER_PK=your_relayer_private_key
VALIDATION_REGISTRY=0xValidationRegistryAddress
